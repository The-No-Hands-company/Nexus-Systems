{
  "name": "nexus-router",
  "version": "0.1.0",
  "description": "Central orchestration engine for Nexus Systems ecosystem — IP routing, auth, AI provider selection, telemetry, and federation",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist",
    "start": "bun run dist/index.js",
    "test": "bun test",
    "lint": "biome check src/ --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "yaml": "^2.4.0",
    "pino": "^8.20.0",
    "pino-pretty": "^10.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.4.0",
    "@biomejs/biome": "^1.7.0"
  }
}
