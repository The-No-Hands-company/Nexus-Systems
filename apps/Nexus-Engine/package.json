{
  "name": "nexus-engine",
  "version": "0.1.0",
  "description": "Unified 2D + 3D game engine for Nexus ecosystem",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
