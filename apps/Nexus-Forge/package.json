{
  "name": "nexus-forge",
  "version": "0.1.0",
  "description": "Self-hosted federated code forge — Git/SVN/Mercurial/Pijul",
  "type": "module",
  "main": "dist/backend/main.js",
  "scripts": {
    "dev": "bun run src/backend/main.ts",
    "build": "tsc && bun build src/backend/main.ts --outfile dist/backend/main.js --external 'better-sqlite3' 'ssh2'",
    "test": "bun test tests/**/*.test.ts",
    "test:watch": "bun test tests/**/*.test.ts --watch",
    "format": "prettier --write 'src/**/*.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "elysia": "^1.1.0",
    "@elysiajs/cors": "^1.4.1",
    "cors": "^2.8.5",
    "better-sqlite3": "^9.2.0",
    "ssh2": "^1.15.0",
    "simple-git": "^3.22.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "jsonwebtoken": "^9.0.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.10.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/ssh2": "^1.11.17",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "prettier": "^3.1.0",
    "vite": "^5.4.0",
    "@vitejs/plugin-react": "^4.2.0"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=22.0.0"
  }
}
