{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus.systems/schemas/ecosystem-graph.v1.json",
  "title": "Nexus Ecosystem Graph Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "nodeCount",
    "edgeCount",
    "nodes",
    "edges"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "nodeCount": {
      "type": "integer",
      "minimum": 0
    },
    "edgeCount": {
      "type": "integer",
      "minimum": 0
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "type", "sources"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(system|capability|surface|doc):"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["system", "capability", "surface", "document"]
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "pattern": "^(?!/).+"
            },
            "uniqueItems": true
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "source", "target", "relation"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^edge:[0-9]+$"
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "relation": {
            "type": "string",
            "enum": [
              "depends_on",
              "integrates_with",
              "owns",
              "exposes",
              "documented_by"
            ]
          }
        }
      }
    }
  }
}