{
  "name": "nexus-monitor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Nexus ecosystem health monitoring service",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests",
    "format": "biome check --write src tests",
    "check": "bun run typecheck && bun run lint"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "bun-types": "^1.1.0",
    "typescript": "^5.4.0"
  }
}
