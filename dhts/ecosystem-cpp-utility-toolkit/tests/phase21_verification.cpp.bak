void print_summary() {
    std::cout << "\n" << std::string(80, '=') << std::endl;
    std::cout << "PHASE 21 VERIFICATION SUMMARY" << std::endl;
    std::cout << std::string(80, '=') << std::endl;
    
    int total = test_results.size();
    int passed = 0;
    
    for (const auto& result : test_results) {
        if (result.passed) passed++;
    }
    
    std::cout << "\nTotal Tests: " << total << std::endl;
    std::cout << "Passed: " << passed << std::endl;
    std::cout << "Failed: " << (total - passed) << std::endl;
    std::cout << "Success Rate: " << (passed * 100 / total) << "%" << std::endl;
    
    std::cout << "\nUtilities by Category:" << std::endl;
    std::cout << "  2D Graphics (Category 22): 4 utilities" << std::endl;
    std::cout << "    - sprite_batch" << std::endl;
    std::cout << "    - canvas_2d" << std::endl;
    std::cout << "    - shape_renderer" << std::endl;
    std::cout << "    - text_renderer_simple" << std::endl;
    
    std::cout << "\n  3D Graphics - Culling (Category 24): 1 utility" << std::endl;
    std::cout << "    - frustum_culler" << std::endl;
    
    std::cout << "\n  Rendering Pipeline (Category 25): 4 utilities" << std::endl;
    std::cout << "    - render_queue" << std::endl;
    std::cout << "    - material_system" << std::endl;
    std::cout << "    - lighting_calculator" << std::endl;
    std::cout << "    - shadow_map_helper" << std::endl;
    
    std::cout << "\n" << std::string(80, '=') << std::endl;
    
    if (passed == total) {
        std::cout << "✓ ALL TESTS PASSED - Complete Graphics/Rendering Stack!" << std::endl;
        std::cout << "\nGraphics Features Now Available:" << std::endl;
        std::cout << "  • 2D sprite batching and rendering" << std::endl;
        std::cout << "  • 2D canvas drawing API" << std::endl;
        std::cout << "  • Optimized shape rendering with tesselation" << std::endl;
        std::cout << "  • Bitmap-based text rendering" << std::endl;
        std::cout << "  • 3D view frustum culling" << std::endl;
        std::cout << "  • Priority-based render queue" << std::endl;
        std::cout << "  • Material property system" << std::endl;
        std::cout << "  • Real-time lighting calculations" << std::endl;
        std::cout << "  • Shadow mapping system" << std::endl;
    } else {
        std::cout << "⚠ SOME TESTS FAILED" << std::endl;
    }
    
    std::cout << std::string(80, '=') << std::endl;
}

int main() {
    std::cout << "╔════════════════════════════════════════════════════════════════════════════╗" << std::endl;
    std::cout << "║                    PHASE 21 VERIFICATION TEST SUITE                        ║" << std::endl;
    std::cout << "║                  Graphics & Rendering Utilities (9 total)                  ║" << std::endl;
    std::cout << "╚════════════════════════════════════════════════════════════════════════════╝" << std::endl;
    
    // Test Category 22: 2D Graphics
    std::cout << "\n>>> Category 22: 2D Graphics (4 utilities)" << std::endl;
    test_2d_graphics::test_sprite_batch();
    test_2d_graphics::test_canvas_2d();
    test_2d_graphics::test_shape_renderer();
    test_2d_graphics::test_text_renderer_simple();
    
    // Test Category 24: 3D Graphics - Culling
    std::cout << "\n>>> Category 24: 3D Graphics - Frustum Culling (1 utility)" << std::endl;
    test_3d_culling::test_frustum_culler();
    
    // Test Category 25: Rendering Pipeline
    std::cout << "\n>>> Category 25: Rendering Pipeline (4 utilities)" << std::endl;
    test_rendering_pipeline::test_render_queue();
    test_rendering_pipeline::test_material_system();
    test_rendering_pipeline::test_lighting_calculator();
    test_rendering_pipeline::test_shadow_map_helper();
    
    // Print summary
    print_summary();
    
    return (test_results.size() == 9 && 
            std::all_of(test_results.begin(), test_results.end(),
                       [](const TestResult& r) { return r.passed; })) ? 0 : 1;
}
