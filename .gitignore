# Public monorepo scope: only apps and docs are publishable
*
!/.gitignore
!/.gitmodules
!/apps/
!/apps/**
!/docs/
!/docs/**

# Local-only paths explicitly excluded from public repo
Nexus-Systems.code-workspace
Nexus_Systems_Ecosystem_Blueprint.md
autopilot.py
VersaAI-LegecyOnly/
scripts/
packages/
dhts/
Backups/

# Secret and local artifact safety (inside allowed folders too)
**/.env
**/.env.*
**/*.pem
**/*.key
**/*.crt
**/*.p12
**/*.pfx
**/*.secret
**/secrets/
**/__pycache__/
**/*.py[cod]
**/*.so
**/.venv/
**/venv/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/node_modules/
**/.npm/
**/.pnpm-store/
**/.yarn/
**/target/
**/dist/
**/build/
**/coverage/
**/.cache/
**/test-results/
**/.DS_Store
**/Thumbs.db
