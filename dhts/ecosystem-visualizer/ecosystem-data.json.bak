    "name": "The No Hands Company",
    "tagline": "Free. Open Source. Forever.",
    "description": "A solo-dev GitHub organization built on three principles: (1) Open Source everything, (2) Free forever \u2014 no paywalls, no subscriptions, no enterprise-tier upsells, (3) The only accepted payment is voluntary donations via PayPal. Every tool offers dual-mode deployment: standalone via docker compose up, or fully managed inside Nexus-Cloud.",
    "principles": [
      "Open Source \u2014 every line of code is public",
      "Free Forever \u2014 no paywalls, no subscriptions, no enterprise tiers",
      "Donations Only \u2014 the only accepted payment is voluntary PayPal donations",
      "Self-Hosted First \u2014 every tool runs standalone via docker compose up",
      "Federated \u2014 tools communicate across instances, no central authority",
      "AI-Native \u2014 every tool has AI deeply integrated, not bolted on",
      "Privacy-First \u2014 no surveillance, no telemetry, no data mining",
      "Sovereign \u2014 users own their data, their infrastructure, their destiny"
    ],
    "donations": {
      "paypal": "paypal.me/TheNoHandsCompany",
      "note": "Voluntary only. No features are gated behind donations."
    },
    "nexusCloudUrl": "https://nexus.cloud",
    "githubOrg": "https://github.com/The-No-Hands-Company"
  },
